{
  "name": "atropos-cli",
  "version": "0.0.0-dev",
  "description": "Reshape messy agent-authored git history into clean, reviewable commits.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "atropos": "./dist/cli.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "RUN_LIVE=1 vitest run",
    "typecheck": "tsc --noEmit",
    "atropos": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@inquirer/prompts": "^7.5.0",
    "commander": "^14.0.0",
    "execa": "^9.5.2",
    "kleur": "^4.1.5",
    "yaml": "^2.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.4"
  }
}
